{
  "manifest_version": 3,
  "name": "WebP to PNG Converter",
  "version": "1.0.0",
  "description": "Automatically converts downloaded WebP images to PNG files.",
  "permissions": [
    "downloads",
    "downloads.open",
    "downloads.shelf"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
